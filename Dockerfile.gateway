FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY api_gateway/ api_gateway/
COPY auth/ auth/
COPY users/ users/
COPY billing/ billing/
COPY orgs/ orgs/
COPY usage/ usage/

CMD ["uvicorn", "api_gateway.main:app", "--host", "0.0.0.0", "--port", "8000"]
